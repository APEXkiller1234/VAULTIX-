{% set topUpAmounts = [5, 10, 25, 50, 100] %}

<div class="container mx-auto customer-balance-page">
  <div class="relative px-4 lg:px-0 py-16 lg:py-32 customer-balance-page__inner">
    <div class="w-full mx-auto flex flex-col gap-4 md:gap-6 lg:gap-8 lg:flex-row">
      <div class="lg:flex-1">
        {% render_snippet "customer-sidebar.njk" %}
      </div>
      <div class="lg:w-3/4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 premium-balance-grid">
          <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-card/75 border border-white/5 premium-balance-card premium-balance-card--wallet">
            <div class="premium-balance-card__orbit" aria-hidden="true"></div>
            <div class="premium-balance-card__content">
              <span class="premium-balance-card__eyebrow">Premium Wallet</span>
              <h3 class="text-lg text-t-primary/80 premium-balance-card__title">
                Balance
              </h3>
              <p class="text-sm text-t-primary/60 mt-1 premium-balance-card__subtitle">
                Customer Balance can be used to pay for future orders.
              </p>
              <p class="mt-4 text-2xl text-t-primary font-semibold premium-balance-card__amount">
                <span x-text="appCurrency.format({{ shop_customer.balance }}, 'USD')">
                  {{ formatPrice(shop_customer.balance, 'USD') }}
                </span>
              </p>
            </div>
          </div>
          <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-card/75 border border-white/5 premium-balance-card premium-balance-card--topup">
            <div class="premium-balance-card__orbit premium-balance-card__orbit--topup" aria-hidden="true"></div>
            <div class="premium-balance-card__content">
              <span class="premium-balance-card__eyebrow">Premium Recharge</span>
              <h3 class="text-lg text-t-primary/80 premium-balance-card__title">
                Top Up
              </h3>
              <div class="mt-1">
                {% if balance_product_id and balance_product_variant_id %}
                  <form x-data="topUpBalance" @submit.prevent="buyCustom" class="balance-topup-form premium-balance-topup-form">
                    <label for="topup-custom-amount" class="block text-sm text-t-primary/60 mb-2 balance-topup-intro">
                      Choose a quick amount or enter a custom top-up.
                    </label>
                    <div class="balance-topup-form__core" aria-hidden="true"></div>
                    {% if altcha %}
                      <div
                        x-cloak
                        x-show="!altchaPayload"
                        class="mb-2 transition-opacity"
                        x-transition:enter="transition ease-out duration-300 transform"
                        x-transition:enter-start="opacity-0"
                        x-transition:enter-end="opacity-100"
                        x-transition:leave="transition ease-in duration-200 transform"
                        x-transition:leave-start="opacity-100"
                        x-transition:leave-end="opacity-0"
                      >
                        <altcha-widget
                          challengejson='{{ altcha | json }}'
                          auto="onload"
                          hidefooter="true"
                          hidelogo="true"
                          x-ref="altcha"
                        ></altcha-widget>
                      </div>
                    {% endif %}
                    <div class="balance-topup-quick">
                      <div class="balance-topup-section-head">
                        <div>
                          <div class="balance-topup-quick__label">Quick Top Up</div>
                          <div class="balance-topup-section-copy">Premium instant amounts.</div>
                        </div>
                      </div>
                      <div class="balance-topup-button-grid">
                        {% for amount in topUpAmounts %}
                          <button
                            type="button"
                            @click="buyAmount({{ amount }})"
                            :disabled="buyingAmount !== null"
                            class="balance-topup-amount glitch-interactive"
                            :class="buyingAmount === {{ amount }} ? 'is-loading' : ''"
                            aria-label="Top up {{ formatPrice(amount, 'USD') }}"
                          >
                            <span class="balance-topup-amount__shine" aria-hidden="true"></span>
                            <span class="balance-topup-amount__value" :class="buyingAmount === {{ amount }} ? 'opacity-0' : 'opacity-100'" x-text="appCurrency.format({{ amount }}, 'USD')">
                              {{ formatPrice(amount, 'USD') }}
                            </span>
                            <template x-if="buyingAmount === {{ amount }}">
                              <span class="absolute inset-0 flex items-center justify-center text-accent-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="size-5 animate-spin" fill="currentColor" viewBox="0 0 256 256"><path d="M232,128a104,104,0,0,1-208,0c0-41,23.81-78.36,60.66-95.27a8,8,0,0,1,6.68,14.54C60.15,61.59,40,93.27,40,128a88,88,0,0,0,176,0c0-34.73-20.15-66.41-51.34-80.73a8,8,0,0,1,6.68-14.54C208.19,49.64,232,87,232,128Z"></path></svg>
                              </span>
                            </template>
                          </button>
                        {% endfor %}
                      </div>
                    </div>

                    <div class="balance-custom-topup-panel">
                      <div class="balance-custom-topup-panel__head">
                        <div>
                          <div class="balance-custom-topup-panel__title">Custom Top Up</div>
                          <div class="balance-custom-topup-panel__subtitle">Premium custom amount.</div>
                        </div>
                        
                      </div>

                      <div class="balance-custom-topup__field">
                        <span class="balance-custom-topup__currency" data-currency-symbol x-text="window.currencySymbols?.[appCurrency.currency] || '$'">$</span>
                        <input
                          id="topup-custom-amount"
                          type="number"
                          min="1"
                          step="1"
                          inputmode="numeric"
                          x-model="customAmount"
                          :disabled="buyingAmount !== null"
                          placeholder="Custom amount"
                          class="balance-custom-topup__input"
                        >
                      </div>

                      <button
                        type="submit"
                        :disabled="buyingAmount !== null"
                        class="balance-custom-topup__button glitch-interactive"
                      >
                        <span class="balance-custom-topup__button-glow" aria-hidden="true"></span>
                        <span :class="buyingAmount === 'custom' ? 'opacity-0' : 'opacity-100'">Add Custom</span>
                        <template x-if="buyingAmount === 'custom'">
                          <span class="absolute inset-0 flex items-center justify-center text-accent-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 animate-spin" fill="currentColor" viewBox="0 0 256 256"><path d="M232,128a104,104,0,0,1-208,0c0-41,23.81-78.36,60.66-95.27a8,8,0,0,1,6.68,14.54C60.15,61.59,40,93.27,40,128a88,88,0,0,0,176,0c0-34.73-20.15-66.41-51.34-80.73a8,8,0,0,1,6.68-14.54C208.19,49.64,232,87,232,128Z"></path></svg>
                          </span>
                        </template>
                      </button>
                    </div>
                  </form>
                {% else %}
                  <p class="text-2xl text-t-primary font-semibold premium-balance-unavailable">
                    Not Available
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
        <div class="mt-4">
          <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-card/75 border border-white/5 premium-balance-card premium-transaction-card">
            <div class="premium-balance-card__orbit premium-balance-card__orbit--transactions" aria-hidden="true"></div>
            <div class="premium-balance-card__content">
              <h3 class="text-lg text-t-primary/80 premium-balance-card__title">
                Transaction History
              </h3>
              <div class="mt-4 overflow-hidden premium-transaction-table-wrap">
                {% if balance_transactions.length > 0 %}
                  <table class="w-full text-left text-sm text-t-primary/80 premium-transaction-table">
                    <thead class="text-xs text-t-primary/60 uppercase bg-white/5">
                      <tr>
                        <th scope="col" class="px-6 py-3">Identifier</th>
                        <th scope="col" class="px-6 py-3">Type</th>
                        <th scope="col" class="px-6 py-3">Description</th>
                        <th scope="col" class="px-6 py-3">Amount</th>
                        <th scope="col" class="px-6 py-3">Date</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for transaction in balance_transactions %}
                        <tr class="border-b border-white/5">
                          <td class="px-6 py-4 capitalize">
                            {{ transaction.id }}
                          </td>
                          <td class="px-6 py-4 capitalize">
                            {{ transaction.type }}
                          </td>
                          <td class="px-6 py-4">
                            {% if transaction.description %}
                              {{ transaction.description }}
                            {% elif transaction.invoice %}
                              <a href="/checkout/{{ transaction.invoice.unique_id }}" target="_blank" class="hover:underline">
                                Invoice {{ transaction.invoice.unique_id }}
                              </a>
                            {% else %}
                              -
                            {% endif %}
                          </td>
                          <td class="px-6 py-4">
                            {{ formatPrice(transaction.amount, 'USD') }}
                          </td>
                          <td class="px-6 py-4">
                            {{ transaction.created_at | formatDateTime }}
                          </td>
                        </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                {% else %}
                  <p class="text-sm text-t-primary/60 premium-empty-state">
                    No balance transactions yet.
                  </p>
                {% endif %}
              </div>
              {% if balance_transactions_paginator.last_page > 1 %}
                {% render_snippet "pagination.njk", paginator=balance_transactions_paginator %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('topUpBalance', () => ({
      amount: null,
      customAmount: '',
      buyingAmount: null,
      altchaPayload: null,

      init: function () {
        {% if altcha %}
          this.addAltchaEventListener();
        {% endif %}
      },

      addAltchaEventListener: function () {
        this.$refs.altcha.addEventListener('statechange', (event) => {
          if (event.detail.state === 'verifying') {
            this.buyNowDisabled = true;
          } else if (event.detail.state === 'verified') {
            this.buyNowDisabled = false;
            this.altchaPayload = event.detail.payload;
          }
        });
      },

      generateRecaptchaToken: async function () {
        return new Promise((resolve) => {
          grecaptcha.ready(
            () =>
              void (async () => {
                const token = await grecaptcha.execute(
                  '{{ shop.recaptcha_key }}',
                  { action: 'buynow_s{{ shop.id }}' },
                );

                resolve(token);
              })(),
          );
        });
      },
      
      normalizeAmount: function (value) {
        const parsed = Number.parseInt(value, 10);
        if (!Number.isFinite(parsed) || parsed < 1) {
          return null;
        }
        return parsed;
      },

      buyCustom: async function () {
        const customAmount = this.normalizeAmount(this.customAmount);
        if (customAmount === null) {
          return;
        }
        await this.buy(customAmount, 'custom');
      },

      buyAmount: async function (amount) {
        await this.buy(amount, amount);
      },

      buy: async function (amount, loadingKey) {
        const topUpAmount = this.normalizeAmount(amount);
        if (topUpAmount === null || this.buyingAmount !== null) {
          return;
        }

        const formData = {
          cart: [{
            productId: {{ balance_product_id }},
            variantId: {{ balance_product_variant_id }},
            quantity: topUpAmount,
          }],
          currency: this.appCurrency.currency,
          shopId: '{{ shop.id }}',
        };

        if (window.shopCustomer?.email) {
          formData.email = window.shopCustomer.email;
        }

        {% if altcha %}
          if (this.altchaPayload) {
            formData.altcha = this.altchaPayload;
          }
        {% elif shop.recaptcha_key %}
          try {
            formData.recaptchaToken = await this.generateRecaptchaToken();
          } catch (error) {
            console.error(error);
          }
        {% endif %}

        try {
          this.buyingAmount = loadingKey;

          const response = await fetch('{{ '/v1/checkout' | apiInternalUrl }}', {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
          });

          const responseData = await response.json();

          if (responseData.url) {
            window.location.href = responseData.url;
          }
        } catch (error) {
          console.error(error);
        } finally {
          this.buyingAmount = null;
          this.amount = null;
        }
      }
    }));
  });
</script>