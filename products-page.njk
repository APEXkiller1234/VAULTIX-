{% set title_to_use = properties.default_title %}
{% if category and properties.category_title %}
  {% set title_to_use = properties.category_title %}
{% endif %}

<section
  class="component reveal-on-scroll"
  data-component-id="{{ componentId }}"
  x-data="{
    openGroupModalId: null,
    filtersModalOpen: false,
    openGroupModal(id) {
      this.openGroupModalId = id;
      document.body.style.overflow = 'hidden';
    },
    closeGroupModal() {
      this.openGroupModalId = null;
      document.body.style.overflow = 'auto';
    },
    openFiltersModal() {
      this.filtersModalOpen = true;
      document.body.style.overflow = 'hidden';
    },
    closeFiltersModal() {
      this.filtersModalOpen = false;
      document.body.style.overflow = 'auto';
    },
    submitForm(event) {
      const form = event?.target;
      if (!form) {
        return;
      }

      const inputs = form.querySelectorAll('input, select, textarea');
      inputs.forEach((input) => {
        if (!input.value) {
          input.disabled = true;
        }
      });

      form.submit();
    }
  }"
>
  <div class="py-6 lg:py-8">
    {% if title_to_use %}
      <div class="flex items-center justify-center mb-4 md:mb-6 lg:mb-8">
        <div class="inline-block">
          <h1 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl">
            {{ title_to_use | renderString }}
          </h1>
          <hr class="w-full border-accent-500 mt-1 md:border-2 md:mt-1.5 lg:mt-2 mx-auto">
        </div>
      </div>
    {% endif %}

    <div class="lg:hidden mb-6">
      <button
        x-on:click="openFiltersModal"
        class="w-full px-6 py-2 flex-1 flex justify-center items-center gap-4 border font-semibold bg-accent-500 border-accent-500 text-t-accent hover:enabled:bg-accent-500/50 transition-colors duration-300 ease-in-out"
      >
        <i class="fa fa-sliders-h"></i>
        <span>Filters &amp; Categories</span>
      </button>
    </div>
  
    <div class="grid lg:grid-cols-[280px_1fr] gap-8">
      <aside class="hidden lg:block">
        <div class="sticky top-8 bg-card/75 border border-white/5 p-4 md:p-5 lg:p-6 text-t-primary">
          <form x-on:submit.prevent="submitForm($event)">
            <div class="mb-4 pb-4 border-b border-white/5 space-y-4">
              <div>
                <label class="block mb-2 font-medium">
                  Categories
                </label>
                <div class="premium-category-tree">
                  <a
                    href="{{ '/products' | shopUrl }}"
                    class="category-link all {% if not category %}is-active{% endif %}"
                  >
                    <span class="category-link__meta">
                      <span class="category-link__title">All Categories</span>
                    </span>
                    <span class="category-link__chev">All</span>
                  </a>
                  {% for cat in category_links %}
                    <a
                      href="{{ cat.url }}"
                      data-depth="{{ cat.depth }}"
                      class="category-link {% if cat.depth == 0 %}root{% else %}child{% endif %} {% if category and category.id == cat.id %}is-active{% endif %}"
                      style="margin-left: {{ (cat.depth * 12) }}px"
                    >
                      <span class="category-link__meta">
                        <span class="category-link__title">
                          {% if cat.depth == 0 %}
                            {{ cat.name }}
                          {% else %}
                            • {{ cat.name }}
                          {% endif %}
                        </span>
                      </span>
                      {% if cat.depth == 0 %}
                        <span class="category-link__chev">Category</span>
                      {% endif %}
                    </a>
                  {% endfor %}
                </div>
              </div>
              <div>
                <label for="filters[keyword]" class="block mb-2 font-medium">
                  Keyword
                </label>
                <input
                  type="text"
                  name="filters[keyword]"
                  id="filters[keyword]"
                  value="{{ filters.keyword }}"
                  placeholder="Search..."
                  class="w-full py-2 px-4 text-t-primary/60 bg-white/5 border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                />
              </div>
              <div>
                <label class="block mb-2 font-medium">
                  Price Range
                </label>
                <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="w-full py-2 pl-4 pr-10 text-t-primary/60 bg-white/5 border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                    />
                    <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="w-full py-2 pl-4 pr-10 text-t-primary/60 bg-white/5 border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                    />
                    <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div class="space-y-4">
              <button
                type="submit"
                class="w-full px-6 py-2 flex justify-center items-center gap-4 text-base text-t-accent font-semibold border border-accent-500 bg-accent-500 transition-colors ease-in-out duration-150 hover:bg-accent-500/50 hover:text-t-primary"
              >
                <span>Apply</span>
                <i class="fa fa-arrow-right"></i>
              </button>
              <a
                href="{{ '/products' | shopUrl }}"
                class="w-full px-6 py-2 flex justify-center items-center gap-4 text-base text-accent-500 font-semibold border border-accent-500 transition-colors duration-150 ease-in-out hover:bg-accent-500/10"
              >
                <span>Reset</span>
                <i class="fa fa-rotate-left"></i>
              </a>
            </div>
          </form>
        </div>
      </aside>

      <div class="min-w-0">
        {% if items.length > 0 %}
          <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
            {% for item in items %}
              <div class="w-full sm:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)] reveal-on-scroll" style="--reveal-delay: {{ loop.index0 * 70 }}ms;">
                {% render_snippet "product-card.njk", product=item %}
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="text-center">
            <i class="fa fa-box-open text-6xl text-t-primary/25 mb-4"></i>
            <p class="text-t-primary/70 text-base">
              No products found matching your criteria.
            </p>
          </div>
        {% endif %}

        {% if items_paginator.last_page > 1 %}
          <div class="mt-8">
            {% render_snippet "pagination.njk", paginator=items_paginator %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% render_snippet "premium-reviews.njk" %}

  <section class="component reveal-on-scroll premium-faq-block" data-component-id="{{ componentId }}-faq">
    <div class="py-6 lg:py-8">
      <div class="flex items-center justify-center mb-4 md:mb-6 lg:mb-8">
        <div class="inline-block">
          <h1 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl">
            Frequently Asked Questions
          </h1>
          <hr class="w-full border-accent-500 mt-1 md:border-2 md:mt-1.5 lg:mt-2 mx-auto">
        </div>
      </div>

      <div class="max-w-4xl mx-auto flex flex-col gap-3">
        {% set faq_items = [
          { question: 'How fast is delivery?', answer: 'Most digital items are delivered instantly after checkout, while some products may need a short processing time depending on stock and verification.' },
          { question: 'Can I resell the products?', answer: 'Yes. Products can be resold unless a product page says otherwise, so you can manage them however you prefer.' },
          { question: 'What if something does not work?', answer: 'If a product is invalid, inaccessible, or non-working, support can review it and provide a replacement when eligible.' },
          { question: 'How do I get support?', answer: 'Use the store support link or contact the team through the channel provided on the site and include your order details.' },
          { question: 'What payment methods are accepted?', answer: 'Available payment methods depend on the store configuration shown at checkout, and the options there will always be the most accurate.' }
        ] %}

        {% for faq in faq_items %}
          <div class="premium-faq-item" x-data="{ open: false }">
            <button type="button" class="premium-faq-question" @click="open = !open">
              <span>{{ faq.question }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="size-5 transition-transform duration-300" :class="{ 'rotate-180': open }">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div x-ref="answer" :style="open ? `max-height: ${$refs.answer.scrollHeight}px` : ''" class="premium-faq-answer">
              <p>{{ faq.answer }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>


  <div
    x-cloak
    x-show="filtersModalOpen"
    class="fixed inset-0 z-50 overflow-y-auto lg:hidden"
  >
    <div class="flex items-center justify-center min-h-screen p-4 text-center">
      <div
        x-show="filtersModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="closeFiltersModal()"
        class="fixed inset-0 transition-opacity bg-black/75"
      ></div>
      <div
        x-show="filtersModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        class="inline-block w-full max-w-lg max-h-[85vh] overflow-y-auto transition-all transform"
      >
        <div class="overflow-hidden text-t-primary text-left border border-white/5 bg-background p-4 md:p-6">
          <div class="flex items-start justify-between gap-4 mb-6">
            <h3 class="text-xl font-bold">
              Filters
            </h3>
            <button @click="closeFiltersModal()" class="text-t-primary focus:outline-none hover:text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
            </button>
          </div>
          <form x-on:submit.prevent="submitForm($event)">
            <div class="mb-4 pb-4 border-b border-white/5 space-y-4">
              <div>
                <label class="block mb-2 font-medium">
                  Categories
                </label>
                <div class="premium-category-tree">
                  <a
                    href="{{ '/products' | shopUrl }}"
                    class="category-link all {% if not category %}is-active{% endif %}"
                  >
                    <span class="category-link__meta">
                      <span class="category-link__title">All Categories</span>
                    </span>
                    <span class="category-link__chev">All</span>
                  </a>
                  {% for cat in category_links %}
                    <a
                      href="{{ cat.url }}"
                      data-depth="{{ cat.depth }}"
                      class="category-link {% if cat.depth == 0 %}root{% else %}child{% endif %} {% if category and category.id == cat.id %}is-active{% endif %}"
                      style="margin-left: {{ (cat.depth * 12) }}px"
                    >
                      <span class="category-link__meta">
                        <span class="category-link__title">
                          {% if cat.depth == 0 %}
                            {{ cat.name }}
                          {% else %}
                            • {{ cat.name }}
                          {% endif %}
                        </span>
                      </span>
                      {% if cat.depth == 0 %}
                        <span class="category-link__chev">Category</span>
                      {% endif %}
                    </a>
                  {% endfor %}
                </div>
              </div>
              <div>
                <label for="filters[keyword]" class="block mb-2 font-medium">
                  Keyword
                </label>
                <input
                  type="text"
                  name="filters[keyword]"
                  id="filters[keyword]"
                  value="{{ filters.keyword }}"
                  placeholder="Search..."
                  class="w-full py-2 px-4 text-t-primary/60 bg-white/5 border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                />
              </div>
              <div>
                <label class="block mb-2 font-medium">
                  Price Range
                </label>
                <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="w-full py-2 pl-4 pr-10 text-t-primary/60 bg-white/5 border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                    />
                    <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="w-full py-2 pl-4 pr-10 text-t-primary/60 bg-white/5 border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                    />
                    <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-xs">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <div class="space-y-4">
              <button
                type="submit"
                class="w-full px-6 py-2 flex justify-center items-center gap-4 text-base text-t-accent font-semibold border border-accent-500 bg-accent-500 transition-colors ease-in-out duration-150 hover:bg-accent-500/50 hover:text-t-primary"
              >
                <span>Apply</span>
                <i class="fa fa-arrow-right"></i>
              </button>
              <a
                href="{{ '/products' | shopUrl }}"
                class="w-full px-6 py-2 flex justify-center items-center gap-4 text-base text-accent-500 font-semibold border border-accent-500 transition-colors duration-150 ease-in-out hover:bg-accent-500/10"
              >
                <span>Reset</span>
                <i class="fa fa-rotate-left"></i>
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  {% for item in items %}
    {% if item.type == 'group' %}
      <div
        x-cloak
        x-show="openGroupModalId == '{{ item.id }}'"
        class="fixed inset-0 z-50 overflow-y-auto"
      >
        <div class="flex items-center justify-center min-h-screen p-4 text-center">
          <div
            x-cloak
            @click="closeGroupModal"
            x-show="openGroupModalId == '{{ item.id }}'"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200 transform"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 transition-opacity bg-black/75"
          ></div>
          <div 
            x-cloak
            x-show="openGroupModalId == '{{ item.id }}'"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
            x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
            x-transition:leave="transition ease-in duration-200 transform"
            x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
            x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
            class="inline-block w-full max-w-[76rem] transition-all transform"
          >
            <div class="overflow-hidden text-t-primary text-left border border-white/5 bg-background p-4 md:p-6">
              <div class="flex items-start justify-between gap-4 mb-4 sm:mb-8">
                <h3 class="text-xl font-bold truncate">
                  {{ item.name }}
                </h3>
                <button @click="closeGroupModal" class="text-t-primary focus:outline-none hover:text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-7 text-t-primary/50 hover:text-accent-500">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4">
                {% for product in item.products %}
                  {% render_snippet "product-card.njk", product=product %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</section>